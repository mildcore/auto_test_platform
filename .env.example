# 固件自动化测试平台 - 环境变量示例
# 复制为 .env 文件并修改配置

# ============================================
# 基础配置（开发和生产通用）
# ============================================

# Flask 环境
FLASK_ENV=production
# SECRET_KEY=your-secret-key-here-change-in-production

# 数据库配置
# MySQL: mysql+pymysql://user:password@host:3306/dbname
# SQLite: sqlite:///data/auto_test.db
DATABASE_URL=mysql+pymysql://testuser:your-mysql-password@db:3306/test_platform

# Redis配置（Celery消息队列）
REDIS_URL=redis://redis:6379/0

# JWT密钥（生产环境必须修改！）
JWT_SECRET_KEY=your-jwt-secret-key-change-in-production-min-32-chars

# ============================================
# 数据库配置（Docker部署时使用）
# ============================================

MYSQL_ROOT_PASSWORD=your-mysql-root-password-change-me
MYSQL_USER=testuser
MYSQL_PASSWORD=your-mysql-password-change-me

# ============================================
# 生产环境特有配置（docker-compose.prod.yml 使用）
# ============================================

# 域名配置（用于 Traefik SSL 证书）
DOMAIN=yourdomain.com

# Let's Encrypt 邮箱（用于 SSL 证书到期通知）
ACME_EMAIL=admin@yourdomain.com

# Traefik Dashboard 认证（可选）
# 使用 htpasswd 生成，格式: user:password
# 示例: admin:admin 的哈希
TRAEFIK_AUTH=admin:$apr1$H6uskkkW$IgXLP6ewTrSuBkTrqE8wj/
